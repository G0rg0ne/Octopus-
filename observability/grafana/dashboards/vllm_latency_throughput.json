{
  "uid": "vllm-latency-throughput",
  "title": "vLLM Latency + Throughput",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["vllm", "prometheus"],
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "model_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "refresh": 1,
        "query": {
          "query": "label_values(vllm:request_success, model_name)"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": { "selected": true, "text": "All", "value": ".*" }
      },
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "refresh": 1,
        "query": {
          "query": "label_values(up, job)"
        },
        "includeAll": false,
        "multi": false,
        "current": { "selected": true, "text": "vllm", "value": "vllm" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(vllm:request_success{model_name=~\"$model_name\"}[1m]))",
          "legendFormat": "rps"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Output tokens / sec",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(vllm:generation_tokens{model_name=~\"$model_name\"}[1m]))",
          "legendFormat": "toks/s"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "KV cache usage (%)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "100 * max(vllm:kv_cache_usage_perc{model_name=~\"$model_name\"})",
          "legendFormat": "kv%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Waiting / Running",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "max(vllm:num_requests_waiting{model_name=~\"$model_name\"})",
          "legendFormat": "waiting"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "max(vllm:num_requests_running{model_name=~\"$model_name\"})",
          "legendFormat": "running"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "TTFT (p50/p95) seconds",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model_name\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model_name\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "E2E latency (p50/p95) seconds",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model_name\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model_name\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Token rates (prompt vs generation)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(vllm:prompt_tokens{model_name=~\"$model_name\"}[1m]))",
          "legendFormat": "prompt_toks/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "sum(rate(vllm:generation_tokens{model_name=~\"$model_name\"}[1m]))",
          "legendFormat": "generation_toks/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "tps" }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Queue depth",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "max(vllm:num_requests_waiting{model_name=~\"$model_name\"})",
          "legendFormat": "waiting"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "max(vllm:num_requests_running{model_name=~\"$model_name\"})",
          "legendFormat": "running"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "KV cache usage (%)",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "100 * max(vllm:kv_cache_usage_perc{model_name=~\"$model_name\"})",
          "legendFormat": "kv%"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}

